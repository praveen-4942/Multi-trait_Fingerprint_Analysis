# ---------------------------- Functions ---------------------------- #

def extract_label(img_path, train=True):
    filename, _ = os.path.splitext(os.path.basename(img_path))
    subject_id, etc = filename.split('__')
    if train:
        gender_code, lr_code, finger_code, _, _ = etc.split('_')
    else:
        gender_code, lr_code, finger_code, _ = etc.split('_')

    # Decode gender
    gender = 'Male' if gender_code == 'M' else 'Female'

    # Decode left/right
    lr = 'Left' if lr_code == 'Left' else 'Right'

    # Decode finger type
    if finger_code == 'thumb':
        finger = 'thumb'
    elif finger_code == 'index':
        finger = 'index'
    elif finger_code == 'middle':
        finger = 'middle'
    elif finger_code == 'ring':
        finger = 'ring'
    elif finger_code == 'little':
        finger = 'little'
    else:
        raise ValueError("Unknown finger type: " + finger_code)

    # Combine into one label
    combined_label = f"{gender}_{lr}_{finger}"

    return np.array([subject_id, combined_label], dtype=object)

def loading_data(paths, train=True):
    data = []
    for path in paths:
        print(f"Loading data from: {path}")
        for img in os.listdir(path):
            try:
                img_array = cv2.imread(os.path.join(path, img), cv2.IMREAD_GRAYSCALE)
                img_resize = cv2.resize(img_array, (img_size, img_size))
                label = extract_label(os.path.join(path, img), train)
                data.append([label[1], img_resize])  # label[1] is combined label
            except Exception as e:
                print(f"Skipping {img}: {e}")
    return data

def loading_test_data(path, train=False):
    data = []
    print(f"Loading test data from: {path}")
    for img in os.listdir(path):
        try:
            img_array = cv2.imread(os.path.join(path, img), cv2.IMREAD_GRAYSCALE)
            img_resize = cv2.resize(img_array, (img_size, img_size))
            label = extract_label(os.path.join(path, img), train)
            data.append([label[1], img_resize])
        except Exception as e:
            print(f"Skipping {img}: {e}")
    return data

import numpy as np
from collections import Counter
from sklearn.model_selection import train_test_split
from tensorflow.keras.utils import to_categorical
import random

# ---------------------------- Load Data ---------------------------- #
# Note: Ensure your 'loading_data' and 'loading_test_data' functions are updated to use
# 'img_size' and 'img_width' for resizing images to (224, 224).
train_data = []
for path in train_paths:
    train_data.extend(loading_data([path], train=True))

test_data = loading_test_data(test_path, train=False)

# ----------------- Organize data by class ----------------- #
train_dict = {}
for label, feature in train_data:
    if label not in train_dict:
        train_dict[label] = []
    train_dict[label].append(feature)

# Find the minimum number of images across all classes
min_train_count = min(len(imgs) for imgs in train_dict.values())

# Balance the training data
X, y = [], []
for label, imgs in train_dict.items():
    selected_imgs = random.sample(imgs, min_train_count)
    X.extend(selected_imgs)
    y.extend([label]*len(selected_imgs))

X = np.array(X).reshape(-1, img_size, img_width, 1) / 255.0
y = np.array(y)

# ----------------- Test Data ----------------- #
test_dict = {}
for label, feature in test_data:
    if label not in test_dict:
        test_dict[label] = []
    test_dict[label].append(feature)

min_test_count = min(len(imgs) for imgs in test_dict.values())

X_test, y_test = [], []
for label, imgs in test_dict.items():
    selected_imgs = random.sample(imgs, min_test_count)
    X_test.extend(selected_imgs)
    y_test.extend([label]*len(selected_imgs))

X_test = np.array(X_test).reshape(-1, img_size, img_width, 1) / 255.0
y_test = np.array(y_test)

# ----------------- Label Mapping ----------------- #
all_labels = sorted(list(set(y.tolist() + y_test.tolist())))
label_to_index = {label: idx for idx, label in enumerate(all_labels)}

y = np.array([label_to_index[label] for label in y])
y_test = np.array([label_to_index[label] for label in y_test])

# ---------------- Split Train/Validation ----------------- #
X_train, X_val, y_train, y_val = train_test_split(X, y, test_size=0.2, random_state=1, stratify=y)

# One-hot encode
y_train = to_categorical(y_train, num_classes)
y_val = to_categorical(y_val, num_classes)
y_test = to_categorical(y_test, num_classes)

# ---------------- Print Class Counts ----------------- #
def print_class_counts(y_array, description):
    counts = Counter(np.argmax(y_array, axis=1))
    print(f"\n{description} class distribution:")
    for idx in range(num_classes):
        print(f"Class {all_labels[idx]}: {counts.get(idx,0)}")

print_class_counts(y_train, "Training")
print_class_counts(y_val, "Validation")
print_class_counts(y_test, "Test")

print("\nTotal samples:")
print("Training:", X_train.shape[0])
print("Validation:", X_val.shape[0])
print("Test:", X_test.shape[0])
